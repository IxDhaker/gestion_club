{% extends 'base.html.twig' %}

{% block title %}Accueil — ClubHub{% endblock %}

{% block body %}

<div class="fade-up">
    <p class="section-eyebrow">Bienvenue</p>
    <h1 class="section-title">Gérez vos clubs & événements</h1>
    <div class="title-divider"></div>
    <p class="section-sub mb-4">Rejoignez un club, participez à des événements et développez vos compétences.</p>
    <div class="d-flex gap-3 mb-5">
        <a href="{{ path('club_index') }}" class="btn-gold">Découvrir les clubs</a>
        <a href="{{ path('event_index') }}" class="btn-outline-gold">Voir les événements</a>
    </div>
</div>

<div class="fade-up fade-up-d1">
    <p class="section-eyebrow">Clubs</p>
    <h2 class="section-title" style="font-size:1.5rem;">Clubs Populaires</h2>
    <div class="title-divider"></div>
    <div class="row g-4 mb-5">
        {% for club in clubs %}
        <div class="col-lg-3 col-md-6">
            <div class="club-card">
                <div class="card-accent-bar"></div>
                <div class="card-body-inner">
                    <span class="card-tag">{{ club.domaine }}</span>
                    <h3 class="card-title-text">{{ club.nom }}</h3>
                    <p class="card-desc">{{ club.description }}</p>
                    <div class="card-meta">
                        <span><i class="bi bi-circle-fill" style="font-size:.5rem;"></i> {{ club.status }}</span>
                    </div>
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-12">
            <p class="text-muted-custom">Aucun club disponible pour le moment.</p>
        </div>
        {% endfor %}
    </div>
</div>

<div class="fade-up fade-up-d2">
    <p class="section-eyebrow">Agenda</p>
    <h2 class="section-title" style="font-size:1.5rem;">Evenements à venir</h2>
    <div class="title-divider"></div>
    <div class="row g-4">
        {% for event in events %}
        <div class="col-lg-4 col-md-6">
            <div class="event-card">
                <div class="card-accent-bar"></div>
                <div class="card-body-inner">
                    <span class="card-tag">{{ event.status }}</span>
                    <h3 class="card-title-text">{{ event.titre }}</h3>
                    <p class="card-desc">{{ event.description }}</p>
                    <div class="card-meta">
                        <span><i class="bi bi-calendar3"></i> {{ event.dateEvent ? event.dateEvent|date('d/m/Y') : '--' }}</span>
                        <span><i class="bi bi-geo-alt"></i> {{ event.lieu }}</span>
                    </div>
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-12">
            <p class="text-muted-custom">Aucun evenement disponible pour le moment.</p>
        </div>
        {% endfor %}
    </div>
</div>

{% endblock %}
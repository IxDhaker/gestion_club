{% extends 'base.html.twig' %}

{% block title %}Participants - {{ event.titre }}{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    <nav class="mb-4" style="font-size:.82rem; color:#888;">
        <a href="{{ path('event_index') }}" style="color:#4f46e5; text-decoration:none;">Evenements</a>
        <i class="bi bi-chevron-right mx-1" style="font-size:.7rem"></i>
        <a href="{{ path('event_show', {id: event.id}) }}" style="color:#4f46e5; text-decoration:none;">{{ event.titre }}</a>
        <i class="bi bi-chevron-right mx-1" style="font-size:.7rem"></i>
        <span>Participants</span>
    </nav>

    <div style="background:white; border-radius:16px; padding:2rem; box-shadow:0 2px 12px rgba(0,0,0,0.07);">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
            <div>
                <h1 style="font-weight:700; color:#1a1a2e; font-size:1.7rem; margin-bottom:.3rem;">Participants</h1>
                <p style="color:#888; margin:0;">{{ participants|length }} inscrit{{ participants|length != 1 ? 's' }} pour {{ event.titre }}</p>
            </div>
            <a href="{{ path('event_show', {id: event.id}) }}" class="btn-muted">
                <i class="bi bi-arrow-left me-1"></i>Retour
            </a>
        </div>

        {% if participants is empty %}
            <div class="text-center py-5">
                <i class="bi bi-people" style="font-size:3rem; color:#ccc;"></i>
                <p class="mt-3" style="color:#888;">Aucun participant pour le moment.</p>
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Statut</th>
                            <th>Date d'inscription</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for participation in participants %}
                            <tr>
                                <td>{{ participation.user ? participation.user.nom : 'Utilisateur supprime' }}</td>
                                <td>{{ participation.user ? participation.user.email : '-' }}</td>
                                <td>{{ participation.status }}</td>
                                <td>{{ participation.dateParticipation ? participation.dateParticipation|date('d M Y') : '-' }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

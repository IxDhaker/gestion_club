{% extends 'base.html.twig' %}

{% block title %}{{ event.titre }} — ClubHub{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">

    <nav class="mb-4" style="font-size:.82rem; color:#888;">
        <a href="{{ path('event_index') }}" style="color:#4f46e5;">Evenements</a>
        <i class="bi bi-chevron-right mx-1" style="font-size:.7rem"></i>
        <span>{{ event.titre }}</span>
    </nav>

    <div style="background:white; border-radius:16px; padding:2.5rem; box-shadow:0 2px 12px rgba(0,0,0,0.07); margin-bottom:2rem;">
        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
            <div>
                <span style="background:#ede9fe; color:#4f46e5; border-radius:6px; padding:2px 10px; font-size:0.72rem; font-weight:600; text-transform:uppercase; margin-bottom:0.75rem; display:inline-block;">
                    <i class="bi bi-calendar-event me-1"></i>Evenement
                </span>
                <h1 style="font-weight:700; color:#1a1a2e; font-size:2rem; margin-bottom:1rem;">{{ event.titre }}</h1>

                <div class="d-flex flex-wrap gap-2">
                    {% if event.dateEvent is defined and event.dateEvent %}
                    <span style="background:#f4f6fb; border:1px solid #e5e7eb; border-radius:8px; padding:6px 14px; font-size:0.82rem; color:#555;">
                        <i class="bi bi-calendar3" style="color:#4f46e5;"></i>
                        {{ event.dateEvent|date('d F Y') }}
                    </span>
                    {% endif %}

                    {% if event.lieu is defined and event.lieu %}
                    <span style="background:#f4f6fb; border:1px solid #e5e7eb; border-radius:8px; padding:6px 14px; font-size:0.82rem; color:#555;">
                        <i class="bi bi-geo-alt" style="color:#4f46e5;"></i>
                        {{ event.lieu }}
                    </span>
                    {% endif %}

                    <span style="background:#f4f6fb; border:1px solid #e5e7eb; border-radius:8px; padding:6px 14px; font-size:0.82rem; color:#555;">
                        <i class="bi bi-people" style="color:#4f46e5;"></i>
                        {{ participants|length }} inscrit{{ participants|length != 1 ? 's' }}
                    </span>

                    {% if spotsLeft is not null %}
                        {% if spotsLeft > 0 %}
                        <span style="background:rgba(90,184,138,.12); border:1px solid rgba(90,184,138,.3); color:#2d8a5e; border-radius:6px; padding:4px 10px; font-size:0.75rem; font-weight:600;">
                            {{ spotsLeft }} place{{ spotsLeft != 1 ? 's' }} restante{{ spotsLeft != 1 ? 's' }}
                        </span>
                        {% else %}
                        <span style="background:rgba(224,90,90,.12); border:1px solid rgba(224,90,90,.3); color:#c0392b; border-radius:6px; padding:4px 10px; font-size:0.75rem; font-weight:600;">
                            <i class="bi bi-x-circle me-1"></i>Complet
                        </span>
                        {% endif %}
                    {% endif %}
                </div>
            </div>

            <div class="d-flex flex-column align-items-end gap-2">
                {% if is_granted('ROLE_PRESIDENT') and event.club and event.club.president == app.user %}
                    <a href="{{ path('event_edit', {id: event.id}) }}"
                       style="background:transparent; color:#4f46e5; border:1px solid #4f46e5; border-radius:8px; padding:8px 20px; font-weight:600; display:inline-block;">
                        <i class="bi bi-pencil me-1"></i>Modifier
                    </a>
                {% endif %}

                {% if is_granted('ROLE_USER') %}
                    {% if userParticipation %}
                        {% if userParticipation.status == 'En attente' %}
                            <button style="background:#fef9c3; color:#92400e; border:1px solid #fde68a; border-radius:8px; padding:8px 20px; font-weight:600;" disabled>
                                <i class="bi bi-hourglass-split me-1"></i>En attente
                            </button>
                        {% elseif userParticipation.status == 'Refuse' %}
                            <form method="post" action="{{ path('event_participate', {id: event.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('participate_' ~ event.id) }}">
                                <button type="submit" style="background:#4f46e5; color:white; border:none; border-radius:8px; padding:8px 20px; font-weight:600;">
                                    <i class="bi bi-arrow-repeat me-1"></i>Renvoyer la demande
                                </button>
                            </form>
                        {% else %}
                            <button style="background:#f4f6fb; color:#888; border:1px solid #e5e7eb; border-radius:8px; padding:8px 20px; font-weight:600;" disabled>
                                <i class="bi bi-check-circle-fill me-1"></i>Inscrit
                            </button>
                        {% endif %}
                    {% elseif spotsLeft is not null and spotsLeft == 0 %}
                        <button style="background:#f4f6fb; color:#888; border:1px solid #e5e7eb; border-radius:8px; padding:8px 20px; font-weight:600;" disabled>
                            <i class="bi bi-x-circle me-1"></i>Complet
                        </button>
                    {% else %}
                        <form method="post" action="{{ path('event_participate', {id: event.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('participate_' ~ event.id) }}">
                            <button type="submit" style="background:#4f46e5; color:white; border:none; border-radius:8px; padding:8px 20px; font-weight:600;">
                                <i class="bi bi-person-plus me-1"></i>Participer
                            </button>
                        </form>
                    {% endif %}
                {% else %}
                    <a href="#" style="background:transparent; color:#4f46e5; border:1px solid #4f46e5; border-radius:8px; padding:8px 20px; font-weight:600; display:inline-block;">
                        <i class="bi bi-lock me-1"></i>Connectez-vous pour participer
                    </a>
                {% endif %}

                {% if is_granted('ROLE_RESPONSABLE') %}
                    <a href="{{ path('event_participants', {id: event.id}) }}"
                       style="background:transparent; color:#4f46e5; border:1px solid #4f46e5; border-radius:8px; padding:6px 16px; font-weight:600; font-size:0.8rem; display:inline-block;">
                        <i class="bi bi-list-ul me-1"></i>Voir les participants
                    </a>
                {% endif %}

                {% if is_granted('ROLE_PRESIDENT') and event.club and event.club.president == app.user %}
                    <a href="{{ path('president_participations') }}"
                       style="background:transparent; color:#4f46e5; border:1px solid #4f46e5; border-radius:8px; padding:6px 16px; font-weight:600; font-size:0.8rem; display:inline-block;">
                        <i class="bi bi-person-check me-1"></i>Gerer les demandes
                    </a>
                {% endif %}

                {% if is_granted('ROLE_ADMIN') and event.status != 'Validé' %}
                <form method="post" action="{{ path('event_validate', {id: event.id}) }}" style="margin-top: 5px;">
                    <input type="hidden" name="_token" value="{{ csrf_token('validate' ~ event.id) }}">
                    <button type="submit" class="btn btn-sm btn-success" style="font-weight:600;">
                        <i class="bi bi-check-circle me-1"></i>Valider l'événement
                    </button>
                </form>
                {% endif %}

                {% if is_granted('ROLE_ADMIN') and event.status != 'Refusé' %}
                <form method="post" action="{{ path('event_reject', {id: event.id}) }}" style="margin-top: 5px;">
                    <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ event.id) }}">
                    <button type="submit" class="btn btn-sm btn-danger" style="font-weight:600;"
                            onclick="return confirm('Êtes-vous sûr de vouloir refuser cet événement ?')">
                        <i class="bi bi-x-circle me-1"></i>Refuser l'événement
                    </button>
                </form>
                {% endif %}

            </div>
        </div>

        {% if event.description %}
        <hr style="border-color:#f4f6fb; margin:1.75rem 0;">
        <p style="color:#555; line-height:1.8; font-size:.96rem;">{{ event.description }}</p>
        {% endif %}
    </div>

    {% if event.status is defined and event.status %}
    <div style="background:white; border-radius:16px; padding:1.5rem; box-shadow:0 2px 12px rgba(0,0,0,0.07);">
        <small style="color:#aaa; font-weight:600; text-transform:uppercase;">Statut</small>
        <p style="color:#1a1a2e; font-weight:600; margin:4px 0 0;">{{ event.status }}</p>
    </div>
    {% endif %}

</div>
{% endblock %}

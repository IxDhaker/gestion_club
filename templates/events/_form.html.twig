{{ form_start(form) }}
    <div class="row g-3">
        <div class="col-12">
            {{ form_label(form.titre) }}
            {{ form_widget(form.titre) }}
            {{ form_errors(form.titre) }}
        </div>

        <div class="col-12">
            {{ form_label(form.description) }}
            {{ form_widget(form.description) }}
            {{ form_errors(form.description) }}
        </div>

        <div class="col-12 col-md-6">
            {{ form_label(form.dateEvent) }}
            {{ form_widget(form.dateEvent) }}
            {{ form_errors(form.dateEvent) }}
        </div>

        <div class="col-12 col-md-6">
            {{ form_label(form.lieu) }}
            {{ form_widget(form.lieu) }}
            {{ form_errors(form.lieu) }}
        </div>

        <div class="col-12">
            {{ form_label(form.club) }}
            {{ form_widget(form.club) }}
            {{ form_errors(form.club) }}
        </div>

        <div class="col-12">
            {{ form_label(form.photoFile) }}
            {{ form_widget(form.photoFile) }}
            {{ form_errors(form.photoFile) }}
        </div>


        <div class="col-12 d-flex gap-2 align-items-center mt-2">
            {{ form_widget(form.submit) }}
            <a href="{{ path('event_index') }}" class="btn btn-secondary mt-3">
                Annuler
            </a>
        </div>
    </div>

{% extends 'base.html.twig' %}

{% block title %}Creer un evenement - ClubHub{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    <nav class="mb-4" style="font-size:.82rem; color:#888;">
        <a href="{{ path('event_index') }}" style="color:#4f46e5; text-decoration:none;">Evenements</a>
        <i class="bi bi-chevron-right mx-1" style="font-size:.7rem"></i>
        <span>Creer</span>
    </nav>

    <div style="background:white; border-radius:16px; padding:2.5rem; box-shadow:0 2px 12px rgba(0,0,0,0.07);">
        <span style="background:#ede9fe; color:#4f46e5; border-radius:6px; padding:2px 10px; font-size:0.72rem; font-weight:600; text-transform:uppercase; margin-bottom:0.75rem; display:inline-block;">
            <i class="bi bi-calendar-plus me-1"></i>President
        </span>
        <h1 style="font-weight:700; color:#1a1a2e; font-size:2rem; margin-bottom:.5rem;">Creer un evenement</h1>
        <p style="color:#888; margin-bottom:1.5rem;">L'evenement sera envoye a l'administration pour validation.</p>

        {% include 'events/_form.html.twig' with {form: form} %}
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Evenements - ClubHub{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">

    <div class="mb-4 d-flex flex-wrap align-items-start justify-content-between gap-3">
        <div>
            <h2 style="font-weight:700; color:#1a1a2e;">Evenements</h2>
            <p style="color:#888;">Inscrivez-vous aux evenements et participez a la vie du campus.</p>
        </div>
        {% if is_granted('ROLE_PRESIDENT') %}
            <a href="{{ path('president_participations') }}" class="btn-outline-gold">
                <i class="bi bi-person-check me-1"></i>Participations recues
            </a>
            <a href="{{ path('event_new') }}" class="btn-gold">
                <i class="bi bi-calendar-plus me-1"></i>Creer un evenement
            </a>
        {% endif %}
    </div>

    {% if events is empty %}
    <div class="text-center py-5">
        <i class="bi bi-calendar-x" style="font-size:3rem; color:#ccc;"></i>
        <p class="mt-3" style="color:#888;">Aucun evenement prevu pour le moment.</p>
    </div>
    {% else %}
    <div class="row g-4">
        {% for event in events %}
        <div class="col-12 col-md-6 col-xl-4">
            <div style="background:white; border-radius:16px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,0.07); transition:transform 0.2s; height:100%;"
                 onmouseover="this.style.transform='translateY(-5px)'"
                 onmouseout="this.style.transform='translateY(0)'">
                <div style="height:4px; background:linear-gradient(90deg, #4f46e5, #7c3aed);"></div>
                <div style="padding:1.5rem; display:flex; flex-direction:column; height:calc(100% - 4px);">

                    <span style="background:#ede9fe; color:#4f46e5; border-radius:6px; padding:2px 10px; font-size:0.72rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:0.75rem; display:inline-block;">
                        <i class="bi bi-calendar-event me-1"></i>
                        {% if event.dateEvent is defined and event.dateEvent %}
                            {{ event.dateEvent|date('d M Y') }}
                        {% else %}
                            TBA
                        {% endif %}
                    </span>

                    <h3 style="font-size:1.2rem; font-weight:700; color:#1a1a2e; margin-bottom:0.5rem;">{{ event.titre }}</h3>

                    <p style="font-size:0.87rem; color:#888; line-height:1.6; flex-grow:1;">
                        {{ event.description|default('Aucune description disponible.')|slice(0, 110) }}...
                    </p>

                    <div style="display:flex; align-items:center; gap:1rem; margin-top:1rem; font-size:0.8rem; color:#888;">
                        {% if event.lieu is defined and event.lieu %}
                        <span><i class="bi bi-geo-alt" style="color:#4f46e5;"></i> {{ event.lieu }}</span>
                        {% endif %}
                        {% if event.club %}
                        <span><i class="bi bi-collection" style="color:#4f46e5;"></i> {{ event.club.nom }}</span>
                        {% endif %}
                    </div>

                    <div class="mt-3 d-flex flex-wrap gap-2">
                        <a href="{{ path('event_show', {id: event.id}) }}"
                           style="background:#4f46e5; color:white; border-radius:8px; padding:8px 20px; font-weight:600; font-size:0.85rem; display:inline-block;">
                            Voir l'evenement
                        </a>
                        {% if is_granted('ROLE_PRESIDENT') and event.club and event.club.president == app.user %}
                            <a href="{{ path('event_edit', {id: event.id}) }}"
                               style="background:transparent; color:#4f46e5; border:1px solid #4f46e5; border-radius:8px; padding:8px 16px; font-weight:600; font-size:0.85rem; display:inline-block;">
                                <i class="bi bi-pencil me-1"></i>Modifier
                            </a>
                        {% endif %}
                    </div>

                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

</div>
{% endblock %}

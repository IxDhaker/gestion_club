{% extends 'base.html.twig' %}

{% block title %}Soumettre une candidature — ClubHub{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            {# ── Header ── #}
            <div class="mb-4 text-center">
                <div style="width:64px; height:64px; background:linear-gradient(135deg,#4f46e5,#7c3aed); border-radius:18px; display:inline-flex; align-items:center; justify-content:center; margin-bottom:16px; box-shadow:0 8px 24px rgba(79,70,229,0.35);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="white" viewBox="0 0 24 24"><path d="M9 12h6m-6 4h6M7 8h.01M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9-4.03-9-9-9z" stroke="white" stroke-width="1.8" fill="none" stroke-linecap="round"/></svg>
                </div>
                <h2 style="font-weight:800; color:#1a1a2e; font-size:1.7rem; margin:0;">Soumettre une candidature</h2>
                <p style="color:#9ca3af; margin-top:6px;">Rejoignez un club qui vous correspond</p>
            </div>

            {# ── Card ── #}
            <div style="background:white; border-radius:20px; padding:40px; box-shadow:0 4px 24px rgba(0,0,0,0.08); border:1px solid #f1f0ff;">

                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                {# Recrutement #}
                <div class="mb-4">
                    <label style="font-weight:700; color:#1a1a2e; font-size:0.85rem; text-transform:uppercase; letter-spacing:.05em; margin-bottom:10px; display:flex; align-items:center; gap:8px;">
                        <span style="width:8px; height:8px; background:#4f46e5; border-radius:50%; display:inline-block;"></span>
                        Poste / Recrutement
                    </label>
                    {{ form_widget(form.recruitment, {
                        'attr': {
                            'class': 'form-select',
                            'style': 'border-radius:12px; border:2px solid #e5e7eb; padding:12px 16px; font-size:0.95rem; color:#1a1a2e; background-color:#fafafa; transition:border-color .2s; outline:none;'
                        }
                    }) }}
                    {% if form_errors(form.recruitment) %}
                        <div style="color:#ef4444; font-size:0.82rem; margin-top:6px;">{{ form_errors(form.recruitment) }}</div>
                    {% endif %}
                </div>

                {# Message #}
                <div class="mb-4">
                    <label style="font-weight:700; color:#1a1a2e; font-size:0.85rem; text-transform:uppercase; letter-spacing:.05em; margin-bottom:10px; display:flex; align-items:center; gap:8px;">
                        <span style="width:8px; height:8px; background:#7c3aed; border-radius:50%; display:inline-block;"></span>
                        Lettre de motivation
                    </label>
                    {{ form_widget(form.message, {
                        'attr': {
                            'class': 'form-control',
                            'rows': 6,
                            'placeholder': 'Présentez-vous et expliquez pourquoi vous souhaitez rejoindre ce recrutement…',
                            'style': 'border-radius:12px; border:2px solid #e5e7eb; padding:14px 16px; font-size:0.95rem; color:#1a1a2e; background-color:#fafafa; line-height:1.6; resize:vertical; transition:border-color .2s;'
                        }
                    }) }}
                    {% if form_errors(form.message) %}
                        <div style="color:#ef4444; font-size:0.82rem; margin-top:6px;">{{ form_errors(form.message) }}</div>
                    {% endif %}
                </div>

                {# Status (responsable/admin only) #}
                {% if form.status is defined %}
                <div class="mb-4">
                    <label style="font-weight:700; color:#1a1a2e; font-size:0.85rem; text-transform:uppercase; letter-spacing:.05em; margin-bottom:10px; display:flex; align-items:center; gap:8px;">
                        <span style="width:8px; height:8px; background:#10b981; border-radius:50%; display:inline-block;"></span>
                        Statut de la candidature
                    </label>
                    {{ form_widget(form.status, {
                        'attr': {
                            'class': 'form-select',
                            'style': 'border-radius:12px; border:2px solid #e5e7eb; padding:12px 16px; font-size:0.95rem; color:#1a1a2e; background-color:#fafafa;'
                        }
                    }) }}
                </div>
                {% endif %}

                {# Tip box #}
                <div style="background:linear-gradient(135deg,#ede9fe,#f5f3ff); border-radius:12px; padding:16px 20px; margin-bottom:28px; display:flex; gap:12px; align-items:flex-start;">
                    <span style="font-size:1.2rem;">💡</span>
                    <p style="margin:0; color:#6d28d9; font-size:0.85rem; line-height:1.6;">
                        Rédigez une lettre sincère et personnalisée. Les responsables de club apprécient la motivation et la clarté.
                    </p>
                </div>

                {# Actions #}
                <div class="d-flex gap-3 align-items-center">
                    <button type="submit"
                            style="background:linear-gradient(135deg,#4f46e5,#7c3aed); color:white; border:none; border-radius:30px; padding:13px 36px; font-weight:700; font-size:0.95rem; cursor:pointer; box-shadow:0 4px 14px rgba(79,70,229,0.4); transition:transform .15s, box-shadow .15s; flex:1;">
                        🚀 Envoyer la candidature
                    </button>
                    <a href="{{ path('app_recruitment_index') }}"
                       style="color:#9ca3af; text-decoration:none; font-weight:600; font-size:0.9rem; white-space:nowrap;">
                        ← Retour
                    </a>
                </div>

                {{ form_end(form) }}

            </div>
        </div>
    </div>
</div>

<style>
.form-select:focus, .form-control:focus {
    border-color: #4f46e5 !important;
    box-shadow: 0 0 0 3px rgba(79,70,229,0.12) !important;
    background-color: #fff !important;
}
button[type=submit]:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(79,70,229,0.5) !important;
}
</style>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <div class="section-eyebrow">{{ is_granted('ROLE_ETUDIANT') ? 'Espace etudiant' : 'Espace utilisateur' }}</div>
            <h1 class="section-title mb-1">Mon Profil</h1>
            <p class="section-sub mb-0">Gerez vos informations personnelles et votre mot de passe.</p>
        </div>
        <span class="avatar-circle" style="width:56px;height:56px;font-size:1.3rem;">
            {{ user.nom|first|upper }}
        </span>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card p-4 h-100">
                <h2 class="h5 fw-bold mb-3">Informations</h2>
                <div class="member-row mb-3">
                    <span class="avatar-circle">{{ user.nom|first|upper }}</span>
                    <div>
                        <div class="fw-semibold">{{ user.nom }}</div>
                        <div class="text-muted-custom small">{{ user.email }}</div>
                    </div>
                </div>
                <div class="stat-chip mb-2">
                    <i class="bi bi-person-badge"></i>
                    {{ is_granted('ROLE_ETUDIANT') ? 'Etudiant' : user.roles|filter(role => role != 'ROLE_USER')|join(', ') }}
                </div>
                <p class="text-muted-custom small mb-0 mt-3">
                    Les changements sont appliques uniquement a votre compte connecte.
                </p>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card p-4">
                <h2 class="h5 fw-bold mb-3">Modifier le profil</h2>

                {{ form_start(profileForm, {'attr': {'novalidate': 'novalidate'}}) }}
                    <div class="row g-3">
                        <div class="col-md-6">
                            {{ form_label(profileForm.nom, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(profileForm.nom, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(profileForm.nom) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_label(profileForm.email, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(profileForm.email, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(profileForm.email) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_label(profileForm.currentPassword, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(profileForm.currentPassword, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(profileForm.currentPassword) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_label(profileForm.plainPassword, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(profileForm.plainPassword, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(profileForm.plainPassword) }}
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a href="{{ path('app_home') }}" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Retour
                        </a>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check2-circle me-1"></i>Enregistrer
                        </button>
                    </div>
                {{ form_end(profileForm) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

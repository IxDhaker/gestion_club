{% extends 'base.html.twig' %}

{% block title %}Sign In — ClubHub{% endblock %}

{% block stylesheets %}
<style>
    .auth-wrapper {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .auth-card {
        width: 100%;
        max-width: 430px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 2.8rem 2.5rem;
        box-shadow: 0 24px 64px rgba(0,0,0,.55);
        animation: fadeUp .5s ease both;
    }

    .auth-logo {
        text-align: center;
        margin-bottom: 1.8rem;
    }
    .auth-logo .logo-icon {
        width: 56px; height: 56px;
        background: var(--accent-soft);
        border: 1px solid rgba(200,169,110,.3);
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        color: var(--accent);
        margin-bottom: 1rem;
    }
    .auth-logo h1 {
        font-size: 1.55rem;
        color: var(--text);
        margin-bottom: .3rem;
    }
    .auth-logo p {
        font-size: .87rem;
        color: var(--muted);
    }

    .field-group {
        margin-bottom: 1.15rem;
    }
    .field-group label {
        display: block;
        font-size: .82rem;
        font-weight: 600;
        letter-spacing: .04em;
        color: var(--muted);
        text-transform: uppercase;
        margin-bottom: .45rem;
    }
    .field-group input {
        width: 100%;
        background: var(--surface-2);
        border: 1px solid var(--border);
        color: var(--text);
        border-radius: 10px;
        padding: .65rem 1rem;
        font-size: .93rem;
        font-family: 'DM Sans', sans-serif;
        transition: border-color .2s, box-shadow .2s;
        outline: none;
    }
    .field-group input:focus {
        border-color: rgba(200,169,110,.5);
        box-shadow: 0 0 0 3px rgba(200,169,110,.12);
        background: var(--surface-2);
        color: var(--text);
    }
    .field-group input::placeholder { color: var(--muted); }

    .remember-row {
        display: flex;
        align-items: center;
        gap: .6rem;
        margin: 1rem 0 1.4rem;
    }
    .remember-row input[type="checkbox"] {
        width: 16px; height: 16px;
        accent-color: var(--accent);
        cursor: pointer;
    }
    .remember-row label {
        font-size: .85rem;
        color: var(--muted);
        cursor: pointer;
    }

    .btn-auth {
        width: 100%;
        padding: .75rem;
        background: linear-gradient(135deg, var(--accent), #e8c97e);
        color: #0f0f13;
        font-weight: 700;
        font-size: .95rem;
        letter-spacing: .04em;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        transition: opacity .2s, transform .15s, box-shadow .2s;
    }
    .btn-auth:hover {
        opacity: .9;
        transform: translateY(-1px);
        box-shadow: 0 6px 24px var(--accent-glow);
    }

    .alert-auth {
        background: rgba(224,90,90,.1);
        border: 1px solid rgba(224,90,90,.3);
        color: var(--danger);
        border-radius: 10px;
        padding: .7rem 1rem;
        font-size: .87rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        margin-bottom: 1.2rem;
    }

    .auth-divider {
        text-align: center;
        margin-top: 1.5rem;
        font-size: .85rem;
        color: var(--muted);
    }
    .auth-divider a { color: var(--accent); font-weight: 600; }
</style>
{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="auth-card">

        {# Logo / Header #}
        <div class="auth-logo">
            <div class="logo-icon"><i class="bi bi-shield-lock-fill"></i></div>
            <h1>Welcome Back</h1>
            <p>Sign in to your ClubHub account</p>
        </div>

        {# Error alert #}
        {% if error %}
        <div class="alert-auth">
            <i class="bi bi-exclamation-triangle-fill"></i>
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
        {% endif %}

        {# Already logged in #}
        {% if app.user %}
        <div class="alert-auth" style="background:rgba(90,184,138,.1);border-color:rgba(90,184,138,.3);color:var(--success);">
            <i class="bi bi-check-circle-fill"></i>
            Logged in as {{ app.user.userIdentifier }}.
            <a href="{{ logout_path() }}" style="color:var(--success);text-decoration:underline;">Logout</a>
        </div>
        {% endif %}

        <form method="post">

            <div class="field-group">
                <label for="inputEmail">Email Address</label>
                <input type="email"
                       value="{{ last_username }}"
                       name="email"
                       id="inputEmail"
                       placeholder="your@email.com"
                       autocomplete="email"
                       required
                       autofocus>
            </div>

            <div class="field-group">
                <label for="inputPassword">Password</label>
                <input type="password"
                       name="password"
                       id="inputPassword"
                       placeholder="••••••••"
                       autocomplete="current-password"
                       required>
            </div>

            <input type="hidden" name="_csrf_token"
                   value="{{ csrf_token('authenticate') }}">

            <div class="remember-row">
                <input type="checkbox" name="_remember_me" id="rememberMe">
                <label for="rememberMe">Remember me</label>
            </div>

            <button type="submit" class="btn-auth">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </button>

        </form>

        <div class="auth-divider">
            Don't have an account?
            <a href="{{ path('app_register') }}">Create one</a>
        </div>

    </div>
</div>
{% endblock %}

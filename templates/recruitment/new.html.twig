{% extends 'base.html.twig' %}

{% block title %}Nouveau Recrutement — ClubHub{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            <div style="background:white; border-radius:16px; padding:40px; box-shadow:0 2px 12px rgba(0,0,0,0.07);">
                
                <div class="mb-4">
                    <h2 style="font-weight:700; color:#1a1a2e;">Nouveau Recrutement</h2>
                    <p style="color:#888;">Remplissez les informations du recrutement</p>
                </div>

                {{ form_start(form) }}
                    <div class="mb-3">
                        <label style="font-weight:600; color:#1a1a2e; margin-bottom:6px; display:block;">Titre</label>
                        {{ form_widget(form.titre, {'attr': {'class': 'form-control', 'style': 'border-radius:10px; border:2px solid #e5e7eb; padding:10px 14px;'}}) }}
                    </div>

                    <div class="mb-3">
                        <label style="font-weight:600; color:#1a1a2e; margin-bottom:6px; display:block;">Description</label>
                        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4, 'style': 'border-radius:10px; border:2px solid #e5e7eb; padding:10px 14px;'}}) }}
                    </div>

                    <div class="mb-3">
                        <label style="font-weight:600; color:#1a1a2e; margin-bottom:6px; display:block;">Date limite</label>
                        {{ form_widget(form.dateLimite, {'attr': {'class': 'form-control', 'style': 'border-radius:10px; border:2px solid #e5e7eb; padding:10px 14px;'}}) }}
                    </div>

                    <div class="mb-4">
                        <label style="font-weight:600; color:#1a1a2e; margin-bottom:6px; display:block;">Statut</label>
                        {{ form_widget(form.status, {'attr': {'class': 'form-control', 'style': 'border-radius:10px; border:2px solid #e5e7eb; padding:10px 14px;'}}) }}
                    </div>

                    {# ── Club du responsable ─────────────────────────────── #}
                    {% if userClub %}
                        <div class="mb-4" style="background:#f0f4ff; border:2px solid #c7d2fe; border-radius:12px; padding:14px 18px; display:flex; align-items:center; gap:14px;">
                            <div style="width:40px; height:40px; border-radius:50%; background:#4f46e5; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="white" viewBox="0 0 16 16">
                                    <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 13A6 6 0 1 1 8 2a6 6 0 0 1 0 12z"/>
                                    <path d="M8 5a1 1 0 1 1 0-2 1 1 0 0 1 0 2zm1 8H7V6h2v7z"/>
                                </svg>
                            </div>
                            <div>
                                <div style="font-size:.75rem; font-weight:700; text-transform:uppercase; color:#6366f1; letter-spacing:.06em; margin-bottom:2px;">Club associé</div>
                                <div style="font-weight:700; color:#1a1a2e; font-size:1rem;">{{ userClub.nom }}</div>
                                {% if userClub.domaine %}
                                    <div style="font-size:.8rem; color:#64748b;">{{ userClub.domaine }}</div>
                                {% endif %}
                            </div>
                        </div>
                    {% else %}
                        <div class="mb-4" style="background:#fff7ed; border:2px solid #fed7aa; border-radius:12px; padding:16px 18px;">
                            <div style="display:flex; align-items:center; gap:10px; margin-bottom:8px;">
                                <span style="font-size:1.3rem;">⚠️</span>
                                <span style="font-weight:700; color:#c2410c; font-size:.95rem;">Aucun club trouvé</span>
                            </div>
                            <p style="color:#7c2d12; font-size:.85rem; margin:0;">
                                Vous n'avez pas encore de club. Vous devez d'abord 
                                <a href="{{ path('club_new') }}" style="color:#ea580c; font-weight:700; text-decoration:underline;">créer un club</a>
                                avant de pouvoir publier un recrutement.
                            </p>
                        </div>
                    {% endif %}

                    <div class="d-flex gap-3">
                        {% if userClub %}
                            <button type="submit" class="btn"
                                    style="background:#4f46e5; color:white; border-radius:25px; padding:10px 28px; font-weight:600;">
                                Enregistrer
                            </button>
                        {% else %}
                            <button type="button" disabled
                                    style="background:#d1d5db; color:#9ca3af; border-radius:25px; padding:10px 28px; font-weight:600; border:none; cursor:not-allowed;"
                                    title="Créez d'abord un club">
                                Enregistrer
                            </button>
                        {% endif %}
                        <a href="{{ path('app_recruitment_index') }}" class="btn"
                           style="border:2px solid #e5e7eb; color:#888; border-radius:25px; padding:10px 28px; font-weight:600;">
                            Annuler
                        </a>
                    </div>
                {{ form_end(form) }}

            </div>
        </div>
    </div>
</div>
{% endblock %}
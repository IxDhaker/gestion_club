{% extends 'base.html.twig' %}

{% block title %}Participations recues - ClubHub{% endblock %}

{% block stylesheets %}
<style>
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        border-radius: 999px;
        padding: .25rem .7rem;
        font-size: .78rem;
        font-weight: 700;
        white-space: nowrap;
    }
    .status-pending { background: #fef9c3; color: #92400e; border: 1px solid #fde68a; }
    .status-accepted { background: #d1fae5; color: #047857; border: 1px solid #a7f3d0; }
    .status-refused { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
    .received-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        overflow: hidden;
    }
    .received-header {
        padding: 1.5rem 1.75rem;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }
    .received-stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .received-stat {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 1.2rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    }
    .received-stat strong {
        display: block;
        color: #1a1a2e;
        font-size: 1.8rem;
        line-height: 1;
    }
    .received-stat span {
        display: block;
        color: #888;
        font-size: .82rem;
        margin-top: .45rem;
    }
    .action-buttons {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: .5rem;
    }
</style>
{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    <div class="mb-4 d-flex flex-wrap align-items-start justify-content-between gap-3">
        <div>
            <div class="section-eyebrow">President</div>
            <h1 class="section-title mb-1">Participations recues</h1>
            <p class="section-sub mb-0">Validez ou refusez les demandes envoyees pour les evenements de vos clubs.</p>
        </div>
        <a href="{{ path('event_index') }}" class="btn-muted">
            <i class="bi bi-arrow-left me-1"></i>Evenements
        </a>
    </div>

    <div class="received-stat-grid">
        <div class="received-stat">
            <strong>{{ stats['En attente'] }}</strong>
            <span>En attente</span>
        </div>
        <div class="received-stat">
            <strong>{{ stats['Inscrit'] }}</strong>
            <span>Acceptees</span>
        </div>
        <div class="received-stat">
            <strong>{{ stats['Refuse'] }}</strong>
            <span>Refusees</span>
        </div>
    </div>

    <div class="received-card">
        <div class="received-header">
            <div>
                <h2 class="h5 fw-bold mb-1">Demandes</h2>
                <p class="text-muted-custom small mb-0">{{ participations|length }} participation{{ participations|length != 1 ? 's' }} recue{{ participations|length != 1 ? 's' }}</p>
            </div>
        </div>

        {% if participations is empty %}
            <div class="text-center py-5">
                <i class="bi bi-inbox" style="font-size:3rem; color:#ccc;"></i>
                <p class="mt-3" style="color:#888;">Aucune demande de participation recue.</p>
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Etudiant</th>
                            <th>Evenement</th>
                            <th>Club</th>
                            <th>Date demande</th>
                            <th>Statut</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for participation in participations %}
                            {% set event = participation.event %}
                            {% set student = participation.user %}
                            <tr>
                                <td>
                                    <div class="fw-semibold">{{ student ? student.nom : 'Utilisateur supprime' }}</div>
                                    <div class="text-muted-custom small">{{ student ? student.email : '-' }}</div>
                                </td>
                                <td>
                                    {% if event %}
                                        <a href="{{ path('event_show', {id: event.id}) }}" class="fw-semibold" style="color:#4f46e5;text-decoration:none;">
                                            {{ event.titre }}
                                        </a>
                                        <div class="text-muted-custom small">{{ event.dateEvent ? event.dateEvent|date('d M Y') : 'Date non definie' }}</div>
                                    {% else %}
                                        Evenement supprime
                                    {% endif %}
                                </td>
                                <td>{{ event and event.club ? event.club.nom : '-' }}</td>
                                <td>{{ participation.dateParticipation ? participation.dateParticipation|date('d M Y') : '-' }}</td>
                                <td>
                                    {% if participation.status == 'En attente' %}
                                        <span class="status-badge status-pending"><i class="bi bi-hourglass-split"></i>En attente</span>
                                    {% elseif participation.status == 'Inscrit' %}
                                        <span class="status-badge status-accepted"><i class="bi bi-check-circle"></i>Acceptee</span>
                                    {% else %}
                                        <span class="status-badge status-refused"><i class="bi bi-x-circle"></i>Refusee</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        {% if participation.status != 'Inscrit' %}
                                            <form method="post" action="{{ path('participation_accept', {id: participation.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('accept_participation_' ~ participation.id) }}">
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="bi bi-check-circle me-1"></i>Accepter
                                                </button>
                                            </form>
                                        {% endif %}
                                        {% if participation.status != 'Refuse' %}
                                            <form method="post" action="{{ path('participation_refuse', {id: participation.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('refuse_participation_' ~ participation.id) }}">
                                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Refuser cette participation ?');">
                                                    <i class="bi bi-x-circle me-1"></i>Refuser
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

<form method="post" action="{{ path('app_reclamation_delete', {'id': reclamation.id}) }}"
      onsubmit="return confirm('Supprimer cette réclamation ?');" style="margin:0;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reclamation.id) }}">
    <button class="btn" style="background:#ef4444; color:white; border-radius:25px; padding:10px 28px; font-weight:600; border:none;">
        Supprimer
    </button>
</form>

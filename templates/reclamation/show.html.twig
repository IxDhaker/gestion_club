{% extends 'base.html.twig' %}

{% block title %}Détail Réclamation — ClubHub{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div style="background:white; border-radius:16px; padding:40px; box-shadow:0 2px 12px rgba(0,0,0,0.07);">

                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <h2 style="font-weight:700; color:#1a1a2e;">{{ reclamation.subject }}</h2>
                        <span style="background:#ede9fe; color:#4f46e5; border-radius:20px; padding:4px 14px; font-size:0.78rem; font-weight:600;">
                            {{ reclamation.status }}
                        </span>
                    </div>
                    <a href="{{ path('app_reclamation_index') }}"
                       style="color:#888; text-decoration:none; font-weight:500;">
                        Retour
                    </a>
                </div>

                <div style="background:#f4f6fb; border-radius:12px; padding:20px; margin-bottom:24px;">
                    <small style="color:#aaa; font-weight:600; text-transform:uppercase;">Message</small>
                    <p style="color:#1a1a2e; margin:8px 0 0; line-height:1.7;">
                        {{ reclamation.message }}
                    </p>
                </div>

                <div style="background:#f4f6fb; border-radius:12px; padding:20px; margin-bottom:30px;">
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <small style="color:#aaa; font-weight:600; text-transform:uppercase;">Date</small>
                            <p style="color:#1a1a2e; font-weight:600; margin:4px 0 0;">
                                {{ reclamation.createdAt ? reclamation.createdAt|date('d/m/Y H:i') : 'Non définie' }}
                            </p>
                        </div>
                        <div class="col-md-6 mb-2">
                            <small style="color:#aaa; font-weight:600; text-transform:uppercase;">Statut</small>
                            <p style="color:#1a1a2e; font-weight:600; margin:4px 0 0;">
                                {{ reclamation.status }}
                            </p>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-3">
                    {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_reclamation_edit', {'id': reclamation.id}) }}"
                       class="btn" style="background:#4f46e5; color:white; border-radius:25px; padding:10px 28px; font-weight:600;">
                        Modifier
                    </a>
                    {{ include('reclamation/_delete_form.html.twig') }}
                    {% endif %}
                </div>

            </div>
        </div>
    </div>
</div>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Mes Réclamations — ClubHub{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 style="font-weight:700; color:#1a1a2e;">Mes Réclamations</h2>
            <p style="color:#888;">Suivez vos réclamations et leur statut</p>
        </div>
        <a href="{{ path('app_reclamation_new') }}" class="btn"
           style="background:#4f46e5; color:white; border-radius:25px; padding:10px 24px; font-weight:600;">
            + Nouvelle réclamation
        </a>
    </div>

    {% if reclamations|length == 0 %}
    <div class="text-center py-5">
        <i class="bi bi-envelope-slash" style="font-size:3rem; color:#ccc;"></i>
        <h5 class="mt-3" style="color:#888;">Vous n'avez aucune réclamation pour le moment</h5>
        <a href="{{ path('app_reclamation_new') }}" class="btn mt-3"
           style="background:#4f46e5; color:white; border-radius:25px; padding:8px 22px; font-weight:600;">
            Créer une réclamation
        </a>
    </div>
    {% else %}
    <div style="background:white; border-radius:16px; padding:24px; box-shadow:0 2px 12px rgba(0,0,0,0.07);">
        <table class="table" style="margin:0;">
            <thead>
                <tr>
                    <th>Sujet</th>
                    <th>Message</th>
                    <th>Statut</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for reclamation in reclamations %}
                <tr>
                    <td style="font-weight:600; color:#1a1a2e;">{{ reclamation.subject }}</td>
                    <td style="color:#888; font-size:0.88rem;">{{ reclamation.message|slice(0, 60) }}...</td>
                    <td>
                        <span style="background:#ede9fe; color:#4f46e5; border-radius:20px; padding:4px 14px; font-size:0.78rem; font-weight:600;">
                            {{ reclamation.status }}
                        </span>
                    </td>
                    <td style="color:#888; font-size:0.85rem;">
                        {{ reclamation.createdAt ? reclamation.createdAt|date('d/m/Y') : '' }}
                    </td>
                    <td>
                        <div class="d-flex gap-2">
                            <a href="{{ path('app_reclamation_show', {'id': reclamation.id}) }}"
                               style="background:#ede9fe; color:#4f46e5; border-radius:20px; padding:4px 14px; font-size:0.78rem; font-weight:600; display:inline-block;">
                                Voir
                            </a>
                            <a href="{{ path('app_reclamation_edit', {'id': reclamation.id}) }}"
                               style="background:#4f46e5; color:white; border-radius:20px; padding:4px 14px; font-size:0.78rem; font-weight:600; display:inline-block;">
                                Modifier
                            </a>
                            <form method="post" action="{{ path('app_reclamation_delete', {'id': reclamation.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reclamation.id) }}">
                                <button type="submit"
                                        style="background:rgba(224,90,90,.1); color:#c0392b; border:none; border-radius:20px; padding:4px 14px; font-size:0.78rem; font-weight:600;"
                                        onclick="return confirm('Supprimer cette réclamation ?')">
                                    Supprimer
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}

</div>
{% endblock %}
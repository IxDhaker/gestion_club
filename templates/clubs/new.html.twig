{% extends 'base.html.twig' %}

{% block title %}Nouveau Club{% endblock %}

{% block body %}

<div class="container mt-5">

    <h2 class="mb-4">Créer un Club</h2>

    {{ form_start(form) }}

    <div class="mb-3">
        {{ form_label(form.name) }}
        {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.name) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.description) }}
        {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.logoFile) }}
        {{ form_widget(form.logoFile, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.logoFile) }}
    </div>

    <button class="btn btn-success">
        Créer
    </button>

    <a href="{{ path('club_index') }}" class="btn btn-secondary">
        Annuler
    </a>

    {{ form_end(form) }}

</div>

{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Clubs — ClubHub{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">

    <div class="mb-4">
        <h2 style="font-weight:700; color:#1a1a2e;">Clubs</h2>
        <p style="color:#888;">Découvrez les clubs et rejoignez ceux qui correspondent à votre passion.</p>
    </div>

    {% if clubs is empty %}
    <div class="text-center py-5">
        <i class="bi bi-journal-x" style="font-size:3rem; color:#ccc;"></i>
        <p class="mt-3" style="color:#888;">Aucun club disponible pour le moment.</p>
    </div>
    {% else %}
    <div class="row g-4">
        {% for club in clubs %}
        <div class="col-12 col-sm-6 col-lg-4">
            <div style="background:white; border-radius:16px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,0.07); transition:transform 0.2s; height:100%;"
                 onmouseover="this.style.transform='translateY(-5px)'"
                 onmouseout="this.style.transform='translateY(0)'">
                <div style="height:4px; background:linear-gradient(90deg, #4f46e5, #7c3aed);"></div>
                <div style="padding:1.5rem; display:flex; flex-direction:column; height:calc(100% - 4px);">
                    <span style="background:#ede9fe; color:#4f46e5; border-radius:6px; padding:2px 10px; font-size:0.72rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:0.75rem; display:inline-block;">
                        <i class="bi bi-people-fill me-1"></i>Club
                    </span>
                    <h3 style="font-size:1.2rem; font-weight:700; color:#1a1a2e; margin-bottom:0.5rem;">{{ club.name }}</h3>
                    <p style="font-size:0.87rem; color:#888; line-height:1.6; flex-grow:1;">
                        {{ club.description|default('Aucune description disponible.')|slice(0, 120) }}...
                    </p>
                    <div style="display:flex; align-items:center; gap:1rem; margin-top:1rem; font-size:0.8rem; color:#888;">
                        <span><i class="bi bi-people" style="color:#4f46e5;"></i> {{ club.clubMembers|length }} membre{{ club.clubMembers|length != 1 ? 's' }}</span>
                    </div>
                    <div class="mt-3">
                        <a href="{{ path('club_show', {id: club.id}) }}"
                           style="background:#4f46e5; color:white; border-radius:8px; padding:8px 20px; font-weight:600; font-size:0.85rem; display:inline-block;">
                            Voir le club
                        </a>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

</div>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}{{ club.nom }} — ClubHub{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">

    {# Fil d'ariane #}
    <nav class="mb-4" style="font-size:.82rem; color:#888;">
        <a href="{{ path('club_index') }}" style="color:#4f46e5; text-decoration:none;">Clubs</a>
        <i class="bi bi-chevron-right mx-1" style="font-size:.7rem"></i>
        <span>{{ club.nom }}</span>
    </nav>

    {# Flash messages #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'danger' ? 'danger' : (type == 'warning' ? 'warning' : (type == 'info' ? 'info' : 'success')) }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# Carte de présentation du Club #}
    <div style="background:white; border-radius:16px; padding:2.5rem; box-shadow:0 2px 12px rgba(0,0,0,0.07); margin-bottom:2rem;">
        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
            <div>
                <span style="background:#ede9fe; color:#4f46e5; border-radius:6px; padding:2px 10px; font-size:0.72rem; font-weight:600; text-transform:uppercase; margin-bottom:0.75rem; display:inline-block;">
                    <i class="bi bi-people-fill me-1"></i>Club
                </span>
                <h1 style="font-weight:700; color:#1a1a2e; font-size:2rem; margin-bottom:1rem;">{{ club.nom }}</h1>
                <div class="d-flex flex-wrap gap-2">
                    <span style="background:#f4f6fb; border:1px solid #e5e7eb; border-radius:8px; padding:6px 14px; font-size:0.82rem; color:#555;">
                        <i class="bi bi-tag" style="color:#4f46e5;"></i>
                        {{ club.domaine }}
                    </span>
                    <span style="background:{% if club.status == 'Actif' %}#d1fae5{% elseif club.status == 'En attente' %}#fef9c3{% else %}#fee2e2{% endif %}; border:1px solid {% if club.status == 'Actif' %}#a7f3d0{% elseif club.status == 'En attente' %}#fde68a{% else %}#fecaca{% endif %}; border-radius:8px; padding:6px 14px; font-size:0.82rem; color:{% if club.status == 'Actif' %}#047857{% elseif club.status == 'En attente' %}#92400e{% else %}#991b1b{% endif %};">
                        <i class="bi bi-circle-fill" style="font-size:0.6rem; margin-right:4px;"></i>
                        {{ club.status }}
                    </span>
                </div>
            </div>
            
            <div class="d-flex gap-2 flex-wrap">

                {# ── BOUTON REJOINDRE (Tâche 6) ─────────────────────────────── #}
                {% if is_granted('ROLE_USER') %}
                    {% if isMember %}
                        <span style="background:#d1fae5; color:#047857; border:1px solid #a7f3d0; border-radius:8px; padding:8px 20px; font-weight:600; display:inline-flex; align-items:center; gap:6px;">
                            <i class="bi bi-check-circle-fill"></i> Déjà membre
                        </span>
                    {% else %}
                        <form method="post" action="{{ path('club_join', {'id': club.id}) }}" style="display:inline-block;">
                            <button type="submit" style="background:#4f46e5; color:white; border:none; border-radius:8px; padding:8px 20px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:6px;">
                                <i class="bi bi-plus-circle"></i> Rejoindre
                            </button>
                        </form>
                    {% endif %}
                {% else %}
                    <a href="{{ path('app_login') }}" style="background:transparent; color:#4f46e5; border:1px solid #4f46e5; border-radius:8px; padding:8px 20px; font-weight:600; display:inline-block; text-decoration:none;">
                        <i class="bi bi-lock me-1"></i>Connectez-vous pour rejoindre
                    </a>
                {% endif %}

                {# ── DEMANDE D'ACTIVATION (Tâche 5) — Président du club ────── #}
                {% if is_granted('ROLE_PRESIDENT') and club.president is not null and club.president == app.user %}
                    {% if club.status == 'Inactif' or club.status == 'Refusé' %}
                        <form method="post" action="{{ path('club_request_activation', {'id': club.id}) }}" style="display:inline-block;">
                            <button type="submit" style="background:#f59e0b; color:white; border:none; border-radius:8px; padding:8px 20px; font-weight:600; cursor:pointer;" onclick="return confirm('Envoyer une demande d\'activation à l\'administrateur ?');">
                                <i class="bi bi-send me-1"></i>Demander l'activation
                            </button>
                        </form>
                    {% elseif club.status == 'En attente' %}
                        <span style="background:#fef9c3; color:#92400e; border:1px solid #fde68a; border-radius:8px; padding:8px 20px; font-weight:600; display:inline-block;">
                            <i class="bi bi-hourglass-split me-1"></i>En attente d'approbation
                        </span>
                    {% endif %}
                {% endif %}

                {# ── ACTIVER / REFUSER (Admin) ─────────────────────────────── #}
                {% if is_granted('ROLE_ADMIN') and club.status == 'En attente' %}
                    <form method="post" action="{{ path('club_activate', {'id': club.id}) }}" style="display:inline-block;">
                        <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('Activer ce club ?');">
                            <i class="bi bi-check-circle me-1"></i>Activer
                        </button>
                    </form>
                    <form method="post" action="{{ path('club_refuse', {'id': club.id}) }}" style="display:inline-block;">
                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Refuser ce club ?');">
                            <i class="bi bi-x-circle me-1"></i>Refuser
                        </button>
                    </form>
                {% endif %}

                {% if is_granted('ROLE_PRESIDENT') or is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('club_edit', {'id': club.id}) }}" class="btn btn-outline-secondary">
                        <i class="bi bi-pencil me-1"></i>Modifier
                    </a>
                {% endif %}
                
                {% if is_granted('ROLE_ADMIN') %}
                    <form method="post" action="{{ path('club_delete', {'id': club.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce club ?');" style="display:inline-block;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ club.id) }}">
                        <button class="btn btn-outline-danger">
                            <i class="bi bi-trash me-1"></i>Supprimer
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>

        {% if club.description %}
            <hr style="border-color:#f4f6fb; margin:1.75rem 0;">
            <p style="color:#555; line-height:1.8; font-size:.96rem; margin-bottom: 2rem;">{{ club.description }}</p>
        {% endif %}
    </div>

    {# Retour aux Clubs #}
    <a href="{{ path('club_index') }}" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-2"></i>Retour aux Clubs
    </a>

</div>
{% endblock %}